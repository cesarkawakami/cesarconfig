// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "close_on_file_delete": true,
  "diff_view_style": "unified",
  "edit_predictions": {
    "provider": "zed",
  },
  "git_panel": {
    "tree_view": true,
  },
  "buffer_font_weight": 400.0,
  "excerpt_context_lines": 5,
  "expand_excerpt_lines": 5,
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "max_tabs": 6,
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
  },
  "preferred_line_length": 110,
  "soft_wrap": "editor_width",
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "double_click_in_multibuffer": "open",
  "inlay_hints": {
    "show_background": true,
    "enabled": true,
  },
  "vim": {
    "use_system_clipboard": "never",
    "toggle_relative_line_numbers": true,
  },
  "agent_ui_font_size": 16.0,
  "file_finder": {
    "include_ignored": "smart",
  },
  "file_scan_exclusions": [],
  "file_scan_inclusions": ["**/.venv", "**/local"],
  "agent": {
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "enable_feedback": false,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gemini-2.5-pro",
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-3b7fd8e2-2aa7-42f2-acfc-9c9c01d3f78c",
      },
    },
  },
  "buffer_line_height": "comfortable",
  "buffer_font_family": "JetBrains Mono NL",
  "terminal": {
    "line_height": "comfortable",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "icon_theme": "Zed (Default)",
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16.0,
  "buffer_font_size": 12,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro",
  },
  "languages": {
    "Kotlin": {
      "language_servers": ["kotlin-lsp"],
    },
    "Python": {
      "language_servers": [
        // "pyrefly",
        "ty",
        // "zuban",
        // "basedpyright",
        "ruff",
      ],
    },
    "Pkl": {
      "language_servers": ["!pkl", "..."],
    },
  },
}
